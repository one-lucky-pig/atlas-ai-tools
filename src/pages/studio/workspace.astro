    function renderEnrichmentPanel() {
      const tool = state.tools[selectedToolIndex];
      const enrichment = tool ? state.enrichments?.[tool.slug] : undefined;
      const draft = enrichmentToDraft(enrichment || createEmptyEnrichment());
      const hasEnrichment = Boolean(tool && enrichment);

      enrichmentStatusNode.innerHTML = `
        <span class="studio-chip ${tool ? "" : "studio-chip-danger"}">
          ${tool ? `当前工具：${tool.name || tool.slug || "未命名工具"}` : "当前没有选中工具"}
        </span>
        <span class="studio-chip ${hasEnrichment ? "" : "studio-chip-danger"}">
