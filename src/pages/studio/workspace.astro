        const parsed = parseImportJson(importKey, importInputNode.value);

        if (importKey === "site") {
          state.site = parsed;
        } else if (importKey === "categories") {
          state.categories = parsed;
          selectedCategoryIndex = state.categories.length ? 0 : -1;
        } else if (importKey === "enrichments") {
          state.enrichments = parsed;
        } else {
          state.tools = parsed;
          selectedToolIndex = state.tools.length ? 0 : -1;
        }

        saveState();
        render();
      } catch (error) {
        alert(error instanceof Error ? error.message : String(error));
      }
    });

