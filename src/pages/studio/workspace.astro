---
import siteConfig from "../../../data/site.json";
import categorySeeds from "../../../data/seeds/categories.json";
import toolSeeds from "../../../data/seeds/tools.json";
import enrichmentCache from "../../../data/generated/enrichments.json";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { createStudioState } from "../../lib/studio";
import type { CategorySeed, SiteConfig, ToolEnrichment, ToolSeed } from "../../lib/factory/types";

const initialState = createStudioState({
  site: siteConfig as SiteConfig,
  categories: categorySeeds as CategorySeed[],
  tools: toolSeeds as ToolSeed[],
  enrichments: enrichmentCache as Record<string, ToolEnrichment>
});
const studioBridgeUrl = "http://127.0.0.1:4323";
---

<BaseLayout
  title="旧版工作台 | Atlas AI Tools"
  description="旧版中文本地后台，用于维护站点配置、分类和工具种子，并导出可回写的 JSON。"
  canonicalPath="/studio/workspace"
  robotsContent="noindex, nofollow"
  mode="studio"
>
  <div class="studio-page">
    <section class="studio-command-surface">
      <div class="eyebrow">New workflow</div>
      <h1>开始管理你的内容工厂</h1>
      <div class="studio-commandbar">
        <span class="studio-commandbar-mark">+</span>
        <input id="studio-global-search" type="search" placeholder="搜索工具、分类或输入一个新工具名..." />
        <button class="studio-button studio-button-accent" id="studio-quick-create-tool">快速新增工具</button>
      </div>
      <div class="studio-shortcuts">
        <button class="studio-chip studio-chip-button" data-scroll-target="studio-panel-site">站点配置</button>
        <button class="studio-chip studio-chip-button" data-scroll-target="studio-panel-resources">资源区</button>
        <button class="studio-chip studio-chip-button" data-scroll-target="studio-panel-ai">AI 增强</button>
        <button class="studio-chip studio-chip-button" data-scroll-target="studio-panel-tasks">本地任务</button>
        <button class="studio-chip studio-chip-button" data-scroll-target="studio-panel-export">导出 JSON</button>
      </div>
    </section>

    <section class="studio-shell">
      <div class="studio-topbar">
        <div class="studio-status" id="studio-status"></div>
        <div class="studio-actions">
          <button class="studio-button" id="reset-studio">恢复项目种子</button>
          <button class="studio-button studio-button-ghost" id="clear-draft">清空本地草稿</button>
          <button class="studio-button studio-button-accent" id="download-all">下载全部 JSON</button>
        </div>
      </div>

      <div class="studio-console">
        <div class="studio-main-column">
          <section class="studio-panel" id="studio-panel-site">
            <div class="studio-panel-head">
              <div>
                <div class="section-kicker">Site settings</div>
                <h2>站点配置</h2>
              </div>
            </div>
            <div class="studio-form studio-form-two">
              <label class="studio-field">
                <span>站点名称</span>
                <input id="site-name" type="text" />
              </label>
              <label class="studio-field">
                <span>域名</span>
                <input id="site-domain" type="text" />
              </label>
              <label class="studio-field">
                <span>完整 URL</span>
                <input id="site-url" type="url" />
              </label>
              <label class="studio-field">
                <span>联系邮箱</span>
                <input id="site-contact-email" type="email" />
              </label>
              <label class="studio-field">
                <span>法务实体</span>
                <input id="site-legal-entity" type="text" />
              </label>
              <label class="studio-field">
                <span>AdSense 发布商 ID</span>
                <input id="site-adsense-publisher-id" type="text" placeholder="ca-pub-xxxxxxxxxxxxxxxx" />
              </label>
              <label class="studio-field studio-field-full">
                <span>Google Search Console 验证码</span>
                <input id="site-google-site-verification" type="text" placeholder="填 content 的值，不要整行 meta 标签" />
              </label>
              <label class="studio-field studio-field-full">
                <span>站点描述</span>
                <textarea id="site-description" rows="3"></textarea>
              </label>
            </div>
          </section>

          <section class="studio-panel" id="studio-panel-resources">
            <div class="studio-panel-head">
              <div>
                <div class="section-kicker">Resources</div>
                <h2>分类与工具资源</h2>
              </div>
            </div>
            <div class="studio-resource-grid">
              <div class="studio-resource-pane">
                <div class="studio-subhead">
                  <div>
                    <div class="section-kicker">分类</div>
                    <h3>分类列表</h3>
                  </div>
                  <button class="studio-button studio-button-small" id="add-category">新增分类</button>
                </div>
                <div class="studio-list" id="category-list"></div>
              </div>

              <div class="studio-resource-pane">
                <div class="studio-subhead">
                  <div>
                    <div class="section-kicker">工具</div>
                    <h3>工具列表</h3>
                  </div>
                  <button class="studio-button studio-button-small" id="add-tool">新增工具</button>
                </div>
                <label class="studio-field">
                  <span>搜索工具</span>
                  <input id="tool-search" type="search" placeholder="按名称或 slug 搜索" />
                </label>
                <div class="studio-list studio-list-tools" id="tool-list"></div>
              </div>
            </div>
          </section>

          <section class="studio-panel" id="studio-panel-editors">
            <div class="studio-editor-grid">
              <div class="studio-editor-pane">
                <div class="studio-panel-head">
                  <div>
                    <div class="section-kicker">Category editor</div>
                    <h2 id="category-editor-title">选择一个分类</h2>
                  </div>
                  <button class="studio-button studio-button-ghost studio-button-small" id="delete-category">删除当前分类</button>
                </div>
                <div class="studio-form">
                  <label class="studio-field">
                    <span>slug</span>
                    <input id="category-slug" type="text" />
                  </label>
                  <label class="studio-field">
                    <span>名称</span>
                    <input id="category-name" type="text" />
                  </label>
                  <label class="studio-field">
                    <span>描述</span>
                    <textarea id="category-description" rows="4"></textarea>
                  </label>
                </div>
              </div>

              <div class="studio-editor-pane studio-editor-pane-wide">
                <div class="studio-panel-head">
                  <div>
                    <div class="section-kicker">Tool editor</div>
                    <h2 id="tool-editor-title">选择一个工具</h2>
                  </div>
                  <button class="studio-button studio-button-ghost studio-button-small" id="delete-tool">删除当前工具</button>
                </div>
                <div class="studio-form studio-form-two">
                  <label class="studio-field">
                    <span>slug</span>
                    <input id="tool-slug" type="text" />
                  </label>
                  <label class="studio-field">
                    <span>工具名</span>
                    <input id="tool-name" type="text" />
                  </label>
                  <label class="studio-field">
                    <span>主分类</span>
                    <select id="tool-category"></select>
                  </label>
                  <label class="studio-field">
                    <span>官网链接</span>
                    <input id="tool-official-url" type="url" />
                  </label>
                  <label class="studio-field">
                    <span>定价模型</span>
                    <input id="tool-pricing-model" type="text" />
                  </label>
                  <label class="studio-field">
                    <span>子分类</span>
                    <textarea id="tool-subcategories" rows="4" placeholder="一行一个"></textarea>
                  </label>
                  <label class="studio-field">
                    <span>核心功能</span>
                    <textarea id="tool-core-features" rows="4" placeholder="一行一个"></textarea>
                  </label>
                  <label class="studio-field">
                    <span>使用场景</span>
                    <textarea id="tool-use-cases" rows="4" placeholder="一行一个"></textarea>
                  </label>
                  <label class="studio-field studio-field-full">
                    <span>目标用户</span>
                    <textarea id="tool-target-users" rows="3" placeholder="一行一个"></textarea>
                  </label>
                </div>
              </div>
            </div>
          </section>

          <section class="studio-panel" id="studio-panel-import">
            <div class="studio-split-grid">
              <div class="studio-split-pane">
                <div class="studio-subhead">
                  <div>
                    <div class="section-kicker">Quick entry</div>
                    <h3>批量新增工具</h3>
                  </div>
                  <button class="studio-button studio-button-small" id="bulk-add-tools">批量导入工具行</button>
                </div>
                <div class="studio-form">
                  <label class="studio-field">
                    <span>默认分类</span>
                    <select id="bulk-category"></select>
                  </label>
                  <label class="studio-field">
                    <span>批量录入文本</span>
                    <textarea
                      id="bulk-tools-input"
                      rows="8"
                      placeholder="每行一个工具，建议格式：工具名|slug|分类slug|官网链接|定价模型|子分类1,子分类2|核心功能1,核心功能2|场景1,场景2|用户1,用户2"
                    ></textarea>
                  </label>
                  <p class="section-lead">
                    支持 `|` 或制表符分隔。第三列分类可留空，留空时会使用上面的默认分类。
                  </p>
                </div>
              </div>

              <div class="studio-split-pane">
                <div class="studio-subhead">
                  <div>
                    <div class="section-kicker">Import JSON</div>
                    <h3>从现有文件或外部表格回填</h3>
                  </div>
                  <div class="studio-tabbar" id="import-tabs"></div>
                </div>
                <div class="studio-actions studio-actions-inline">
                  <button class="studio-button studio-button-small" id="apply-import">应用当前导入</button>
                  <button class="studio-button studio-button-small studio-button-ghost" id="clear-import">清空导入框</button>
                </div>
                <label class="studio-field">
                  <span id="import-label">导入内容</span>
                  <textarea id="import-input" rows="10" placeholder="把 JSON 粘贴到这里"></textarea>
                </label>
              </div>
            </div>
          </section>
        </div>

        <aside class="studio-side-column">
          <section class="studio-panel" id="studio-panel-readiness">
            <div class="studio-panel-head">
              <div>
                <div class="section-kicker">Release checks</div>
                <h2>发布前检查</h2>
              </div>
            </div>
            <div class="studio-checklist" id="readiness-list"></div>
          </section>

          <section class="studio-panel" id="studio-panel-files">
            <div class="studio-panel-head">
              <div>
                <div class="section-kicker">Local files</div>
                <h2>直接保存到项目 JSON</h2>
              </div>
              <button class="studio-button studio-button-small" id="save-bound-files">保存已绑定文件</button>
            </div>
            <div class="studio-file-grid" id="file-handle-list"></div>
            <p class="section-lead">
              首次需要手动绑定文件。若浏览器支持，会尝试记住你选择的文件句柄；不支持时仍可继续使用复制/下载导出。
            </p>
          </section>

          <section class="studio-panel" id="studio-panel-tasks">
            <div class="studio-panel-head">
              <div>
                <div class="section-kicker">Local bridge</div>
                <h2>一键触发生成与构建</h2>
              </div>
              <button class="studio-button studio-button-small studio-button-ghost" id="refresh-bridge">刷新连接</button>
            </div>
            <div class="studio-status" id="bridge-status"></div>
            <div class="studio-actions studio-actions-stack" id="bridge-job-buttons"></div>
            <label class="studio-field">
              <span>最近一次任务输出</span>
              <textarea id="bridge-log" rows="10" readonly></textarea>
            </label>
            <p class="section-lead">
              先在另一个终端运行 <code>npm run studio:bridge</code>，然后你就可以直接在这里触发生成、校验、构建和单次调度。
            </p>
          </section>

          <section class="studio-panel" id="studio-panel-ai">
            <div class="studio-panel-head">
              <div>
                <div class="section-kicker">AI enrichment</div>
                <h2>当前工具的补全结果</h2>
              </div>
              <div class="studio-actions studio-actions-inline">
                <button class="studio-button studio-button-small" id="enrich-current-tool">AI 补全当前工具</button>
                <button class="studio-button studio-button-small studio-button-ghost" id="force-enrich-current-tool">强制重新生成</button>
              </div>
            </div>
            <div class="studio-status" id="enrichment-status"></div>
            <div class="studio-form studio-form-two">
              <label class="studio-field studio-field-full">
                <span>摘要</span>
                <textarea id="enrichment-summary" rows="3" placeholder="一句到两句说明这个工具最适合什么人、做什么。"></textarea>
              </label>
              <label class="studio-field studio-field-full">
                <span>Meta Description</span>
                <textarea id="enrichment-meta-description" rows="2" placeholder="搜索结果摘要。"></textarea>
              </label>
              <label class="studio-field">
                <span>优点</span>
                <textarea id="enrichment-pros" rows="4" placeholder="一行一个"></textarea>
              </label>
              <label class="studio-field">
                <span>缺点</span>
                <textarea id="enrichment-cons" rows="4" placeholder="一行一个"></textarea>
              </label>
              <label class="studio-field">
                <span>替代品 slug</span>
                <textarea id="enrichment-alternatives" rows="4" placeholder="一行一个"></textarea>
              </label>
              <label class="studio-field">
                <span>选题角度</span>
                <textarea id="enrichment-editorial-angles" rows="4" placeholder="一行一个"></textarea>
              </label>
              <label class="studio-field">
                <span>FAQ</span>
                <textarea id="enrichment-faq" rows="5" placeholder="每行一组：问题 | 答案"></textarea>
              </label>
              <label class="studio-field">
                <span>内链建议</span>
                <textarea id="enrichment-links" rows="5" placeholder="每行一组：标题 | /path"></textarea>
              </label>
            </div>
            <div class="studio-actions studio-actions-inline">
              <button class="studio-button studio-button-small" id="apply-enrichment-form">应用结构化增强资料</button>
              <button class="studio-button studio-button-small studio-button-ghost" id="apply-enrichment-json">应用增强 JSON</button>
            </div>
            <label class="studio-field">
              <span>增强资料 JSON（高级模式）</span>
              <textarea id="enrichment-json" rows="10" placeholder="为当前工具生成后，会在这里显示 enrichment JSON。"></textarea>
            </label>
          </section>

          <section class="studio-panel" id="studio-panel-export">
            <div class="studio-panel-head">
              <div>
                <div class="section-kicker">Export</div>
                <h2>JSON 导出区</h2>
              </div>
              <div class="studio-tabbar" id="export-tabs"></div>
            </div>
            <div class="studio-actions studio-actions-inline">
              <button class="studio-button studio-button-small" id="copy-export">复制当前 JSON</button>
              <button class="studio-button studio-button-small studio-button-ghost" id="download-export">下载当前 JSON</button>
            </div>
            <label class="studio-field">
              <span id="export-label">导出内容</span>
              <textarea id="export-output" rows="12" readonly></textarea>
            </label>
          </section>
        </aside>
      </div>
    </section>
  </div>

  <style>
    .studio-page {
      display: grid;
      gap: 1rem;
      padding-top: 1rem;
      color: #111827;
    }

    .studio-shell {
      display: grid;
      gap: 1rem;
    }

    .studio-command-surface,
    .studio-panel {
      background: #ffffff;
      border: 1px solid #e5e7eb;
      border-radius: 20px;
      box-shadow: 0 10px 24px rgba(15, 23, 42, 0.03);
      padding: 1.25rem;
    }

    .studio-command-surface {
      display: grid;
      gap: 1rem;
    }

    .studio-command-surface h1 {
      margin: 0.15rem 0 0.45rem;
      font-size: clamp(2.6rem, 5vw, 4.2rem);
      line-height: 0.95;
      font-weight: 700;
    }

    .studio-command-surface p {
      margin: 0;
      max-width: 58ch;
      line-height: 1.7;
      color: #4b5563;
    }

    .studio-commandbar {
      display: grid;
      grid-template-columns: 56px minmax(0, 1fr) auto;
      align-items: center;
      border: 1px solid #e5e7eb;
      border-radius: 18px;
      min-height: 72px;
      background: #ffffff;
      overflow: hidden;
    }

    .studio-commandbar-mark {
      display: grid;
      place-items: center;
      font-size: 1.5rem;
      color: #9ca3af;
      border-right: 1px solid #e5e7eb;
      height: 100%;
    }

    .studio-commandbar input {
      border: 0;
      background: transparent;
      font-size: 1.1rem;
      padding: 0 1rem;
      min-width: 0;
    }

    .studio-commandbar input:focus {
      outline: none;
      box-shadow: none;
    }

    .studio-commandbar .studio-button {
      margin-right: 0.75rem;
    }

    .studio-shortcuts {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
      align-items: center;
    }

    .studio-chip-button {
      cursor: pointer;
      transition: border-color 140ms ease, transform 140ms ease;
    }

    .studio-chip-button:hover {
      transform: translateY(-1px);
      border-color: rgba(59, 130, 246, 0.28);
    }

    .studio-topbar {
      position: sticky;
      top: 5.5rem;
      z-index: 12;
      padding: 0.85rem 1rem;
      background: rgba(255, 255, 255, 0.92);
      border: 1px solid #e5e7eb;
      border-radius: 18px;
      backdrop-filter: blur(14px);
      box-shadow: 0 10px 24px rgba(15, 23, 42, 0.04);
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .studio-console {
      display: grid;
      grid-template-columns: minmax(0, 1.18fr) 400px;
      gap: 1rem;
      align-items: start;
    }

    .studio-main-column,
    .studio-side-column {
      display: grid;
      gap: 1rem;
      align-content: start;
    }

    .studio-side-column {
      position: sticky;
      top: 10.6rem;
    }

    .studio-resource-grid,
    .studio-editor-grid,
    .studio-split-grid,
    .studio-main-grid {
      display: grid;
      gap: 1rem;
    }

    .studio-resource-grid,
    .studio-editor-grid,
    .studio-split-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .studio-editor-pane-wide {
      grid-column: 1 / -1;
    }

    .studio-subhead {
      display: flex;
      justify-content: space-between;
      align-items: start;
      gap: 1rem;
      margin-bottom: 0.85rem;
      flex-wrap: wrap;
    }

    .studio-subhead h3 {
      margin: 0.1rem 0 0;
      font-size: 1.12rem;
      font-weight: 600;
      letter-spacing: -0.03em;
    }

    .studio-side-column .studio-panel,
    .studio-resource-pane,
    .studio-editor-pane,
    .studio-split-pane {
      background: #ffffff;
    }

    .studio-summary-card small,
    .studio-side-card li,
    .studio-side-card p,
    .studio-panel p,
    .studio-panel li {
      color: #6b7280;
      line-height: 1.6;
    }

    .studio-status,
    .studio-actions,
    .studio-tabbar,
    .studio-actions-inline {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
      align-items: center;
    }

    .studio-actions-stack {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.65rem;
    }

    .studio-chip {
      padding: 0.65rem 0.9rem;
      border-radius: 999px;
      background: #ffffff;
      border: 1px solid #e5e7eb;
      color: #6b7280;
      font-size: 0.92rem;
    }

    .studio-chip-danger {
      color: #b45309;
      border-color: rgba(245, 158, 11, 0.26);
      background: #fff7ed;
    }

    .studio-panel {
      background: #ffffff;
      border: 1px solid #e5e7eb;
      border-radius: 20px;
      box-shadow: 0 10px 24px rgba(15, 23, 42, 0.03);
      padding: 1.2rem;
    }

    .studio-panel-span-2 {
      grid-column: 1 / -1;
    }

    .studio-panel-head {
      display: flex;
      justify-content: space-between;
      align-items: start;
      gap: 1rem;
      margin-bottom: 1rem;
      flex-wrap: wrap;
    }

    .studio-panel-head h2 {
      margin: 0.15rem 0 0;
      font-size: 1.28rem;
      font-weight: 600;
    }

    .studio-list {
      display: grid;
      gap: 0.7rem;
      max-height: 20rem;
      overflow: auto;
      padding-right: 0.2rem;
    }

    .studio-list-item {
      width: 100%;
      text-align: left;
      border: 1px solid #e5e7eb;
      background: #fbfbfc;
      border-radius: 14px;
      padding: 0.85rem;
      cursor: pointer;
      transition: transform 140ms ease, border-color 140ms ease, box-shadow 140ms ease;
      color: #111827;
      position: relative;
      overflow: hidden;
    }

    .studio-list-item:hover,
    .studio-list-item-active {
      transform: translateY(-1px);
      border-color: rgba(59, 130, 246, 0.28);
      box-shadow: 0 10px 24px rgba(59, 130, 246, 0.08);
    }

    .studio-list-item-active {
      background: linear-gradient(180deg, #ffffff, #f8fbff);
    }

    .studio-list-item-active::before {
      content: "";
      position: absolute;
      left: 0;
      top: 0;
      bottom: 0;
      width: 4px;
      background: #2563eb;
    }

    .studio-list-item strong {
      display: block;
      font-family: "Iowan Old Style", "Palatino Linotype", "Book Antiqua", Georgia, serif;
      font-size: 1rem;
      margin-bottom: 0.3rem;
    }

    .studio-list-item small {
      display: block;
      color: #6b7280;
      line-height: 1.5;
    }

    .studio-list-item-meta {
      display: flex;
      gap: 0.45rem;
      flex-wrap: wrap;
