    document.getElementById("studio-quick-create-tool").addEventListener("click", () => {
      const raw = globalSearchNode.value.trim();
      if (!raw) {
        alert("先输入一个工具名，再快速创建。");
        return;
      }

      const existingIndex = findToolIndexByQuery(raw);
      if (existingIndex >= 0) {
        selectedToolIndex = existingIndex;
        toolSearch = raw;
        saveState();
        render();
        scrollToPanel("studio-panel-editors");
        return;
      }

      let slug = slugify(raw);
      let suffix = 2;
      while (state.tools.some((tool) => tool.slug === slug)) {
        slug = `${slugify(raw)}-${suffix}`;
        suffix += 1;
      }

      const draft = createEmptyTool(state.categories[0]?.slug || "");
      draft.name = raw;
      draft.slug = slug;
      state.tools.push(draft);
      selectedToolIndex = state.tools.length - 1;
      globalSearchNode.value = "";
      saveState();
      render();
      scrollToPanel("studio-panel-editors");
    });

