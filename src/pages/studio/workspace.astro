    }
  </style>

  <script define:vars={{ initialState, studioBridgeUrl }}>
    const storageKey = "atlas-ai-tools-studio:v1";
    const exportKeys = ["site", "categories", "tools", "enrichments"];
    const importKeys = ["site", "categories", "tools", "enrichments"];
    const fileAccessSupported = typeof window.showSaveFilePicker === "function" && typeof indexedDB !== "undefined";
    let state = loadState();
    let selectedCategoryIndex = state.categories.length ? 0 : -1;
    let selectedToolIndex = state.tools.length ? 0 : -1;
    let exportKey = "site";
    let importKey = "site";
    let toolSearch = "";
    let bridgeState = {
      ok: false,
      busy: false,
      jobs: [],
      message: "尚未连接本地任务桥。",
      log: ""
    };
    let enrichmentState = {
      provider: "",
      cached: false,
      message: "还没有为当前工具生成增强资料。"
    };
    let fileHandles = { site: null, categories: null, tools: null, enrichments: null };
    let fileHandleStatus = {
      site: fileAccessSupported ? "未绑定文件" : "当前浏览器不支持直接回写",
      categories: fileAccessSupported ? "未绑定文件" : "当前浏览器不支持直接回写",
      tools: fileAccessSupported ? "未绑定文件" : "当前浏览器不支持直接回写",
      enrichments: fileAccessSupported ? "未绑定文件" : "当前浏览器不支持直接回写"
    };

    const statusNode = document.getElementById("studio-status");
    const globalSearchNode = document.getElementById("studio-global-search");
    const categoryListNode = document.getElementById("category-list");
    const toolListNode = document.getElementById("tool-list");
    const exportTabsNode = document.getElementById("export-tabs");
    const exportOutputNode = document.getElementById("export-output");
    const exportLabelNode = document.getElementById("export-label");
    const fileHandleListNode = document.getElementById("file-handle-list");
    const bridgeStatusNode = document.getElementById("bridge-status");
    const bridgeLogNode = document.getElementById("bridge-log");
    const bridgeJobButtonsNode = document.getElementById("bridge-job-buttons");
    const readinessListNode = document.getElementById("readiness-list");
    const importTabsNode = document.getElementById("import-tabs");
    const importInputNode = document.getElementById("import-input");
    const importLabelNode = document.getElementById("import-label");
    const bulkCategoryNode = document.getElementById("bulk-category");
    const bulkToolsInputNode = document.getElementById("bulk-tools-input");
    const enrichmentStatusNode = document.getElementById("enrichment-status");
    const enrichmentJsonNode = document.getElementById("enrichment-json");
    const enrichmentFields = {
      summary: document.getElementById("enrichment-summary"),
      metaDescription: document.getElementById("enrichment-meta-description"),
      prosText: document.getElementById("enrichment-pros"),
      consText: document.getElementById("enrichment-cons"),
      alternativesText: document.getElementById("enrichment-alternatives"),
      editorialAnglesText: document.getElementById("enrichment-editorial-angles"),
      faqText: document.getElementById("enrichment-faq"),
      suggestedLinksText: document.getElementById("enrichment-links")
    };

    const siteFields = {
      name: document.getElementById("site-name"),
      domain: document.getElementById("site-domain"),
      url: document.getElementById("site-url"),
      contactEmail: document.getElementById("site-contact-email"),
      legalEntity: document.getElementById("site-legal-entity"),
      adsensePublisherId: document.getElementById("site-adsense-publisher-id"),
      googleSiteVerification: document.getElementById("site-google-site-verification"),
      description: document.getElementById("site-description")
    };

    const categoryFields = {
      title: document.getElementById("category-editor-title"),
      slug: document.getElementById("category-slug"),
      name: document.getElementById("category-name"),
      description: document.getElementById("category-description")
    };

    const toolFields = {
      title: document.getElementById("tool-editor-title"),
      slug: document.getElementById("tool-slug"),
      name: document.getElementById("tool-name"),
      category: document.getElementById("tool-category"),
      officialUrl: document.getElementById("tool-official-url"),
      pricingModel: document.getElementById("tool-pricing-model"),
      subcategories: document.getElementById("tool-subcategories"),
      coreFeatures: document.getElementById("tool-core-features"),
      useCases: document.getElementById("tool-use-cases"),
      targetUsers: document.getElementById("tool-target-users")
    };

    function slugify(value) {
      return value
        .toLowerCase()
        .trim()
        .replace(/[^a-z0-9]+/g, "-")
        .replace(/^-+|-+$/g, "");
    }

    function clone(value) {
      return JSON.parse(JSON.stringify(value));
    }

    function openHandleDatabase() {
      return new Promise((resolve, reject) => {
        const request = indexedDB.open("atlas-ai-tools-studio-files", 1);
        request.onupgradeneeded = () => {
          const db = request.result;
          if (!db.objectStoreNames.contains("handles")) {
            db.createObjectStore("handles");
          }
        };
        request.onsuccess = () => resolve(request.result);
        request.onerror = () => reject(request.error);
      });
    }

    async function getStoredHandle(key) {
      const db = await openHandleDatabase();
      return new Promise((resolve, reject) => {
        const transaction = db.transaction("handles", "readonly");
        const request = transaction.objectStore("handles").get(key);
        request.onsuccess = () => resolve(request.result ?? null);
        request.onerror = () => reject(request.error);
      });
    }

    async function setStoredHandle(key, handle) {
      const db = await openHandleDatabase();
      return new Promise((resolve, reject) => {
        const transaction = db.transaction("handles", "readwrite");
        transaction.objectStore("handles").put(handle, key);
        transaction.oncomplete = () => resolve();
        transaction.onerror = () => reject(transaction.error);
      });
    }

    async function clearStoredHandle(key) {
      const db = await openHandleDatabase();
      return new Promise((resolve, reject) => {
        const transaction = db.transaction("handles", "readwrite");
        transaction.objectStore("handles").delete(key);
        transaction.oncomplete = () => resolve();
        transaction.onerror = () => reject(transaction.error);
      });
    }

    function loadState() {
      const raw = localStorage.getItem(storageKey);
      if (!raw) return clone(initialState);

      try {
        const parsed = JSON.parse(raw);
        return {
          site: { ...clone(initialState.site), ...(parsed.site || {}) },
          categories: Array.isArray(parsed.categories) ? parsed.categories : clone(initialState.categories),
          tools: Array.isArray(parsed.tools) ? parsed.tools : clone(initialState.tools),
          enrichments:
            parsed.enrichments && typeof parsed.enrichments === "object" && !Array.isArray(parsed.enrichments)
              ? parsed.enrichments
              : clone(initialState.enrichments || {})
        };
      } catch {
        return clone(initialState);
      }
    }

    function saveState() {
      localStorage.setItem(storageKey, JSON.stringify(state));
    }

    function listToLines(items) {
      return items.join("\n");
    }

    function linesToList(value) {
      return value
        .split("\n")
        .map((item) => item.trim())
        .filter(Boolean);
    }

    function createEmptyCategory() {
      return { slug: "", name: "", description: "" };
    }

    function createEmptyTool(category = state.categories[0]?.slug || "") {
      return {
        slug: "",
        name: "",
        category,
        subcategories: [],
        officialUrl: "",
        pricingModel: "",
        coreFeatures: [],
        useCases: [],
        targetUsers: []
      };
    }

    function createEmptyEnrichment() {
      return {
        summary: "",
        pros: [],
        cons: [],
        alternatives: [],
        faq: [],
        metaDescription: "",
        editorialAngles: [],
        suggestedInternalLinks: []
      };
    }

    function enrichmentToDraft(enrichment) {
      return {
        summary: enrichment.summary || "",
        metaDescription: enrichment.metaDescription || "",
        prosText: listToLines(enrichment.pros || []),
        consText: listToLines(enrichment.cons || []),
        alternativesText: listToLines(enrichment.alternatives || []),
        editorialAnglesText: listToLines(enrichment.editorialAngles || []),
        faqText: (enrichment.faq || [])
          .map((item) => `${item.question || ""} | ${item.answer || ""}`)
          .join("\n"),
        suggestedLinksText: (enrichment.suggestedInternalLinks || [])
          .map((item) => `${item.label || ""} | ${item.href || ""}`)
          .join("\n")
      };
    }

    function draftToEnrichment(draft) {
      return {
        summary: draft.summary.trim(),
        metaDescription: draft.metaDescription.trim(),
        pros: linesToList(draft.prosText),
        cons: linesToList(draft.consText),
        alternatives: linesToList(draft.alternativesText),
        editorialAngles: linesToList(draft.editorialAnglesText),
        faq: linesToList(draft.faqText).map((line) => {
          const [question = "", answer = ""] = line.split("|").map((item) => item.trim());
          return { question, answer };
        }),
        suggestedInternalLinks: linesToList(draft.suggestedLinksText).map((line) => {
          const [label = "", href = ""] = line.split("|").map((item) => item.trim());
          return { label, href };
        })
      };
    }

    function parseImportJson(kind, raw) {
      const parsed = JSON.parse(raw);

      if (kind === "site") {
        if (
          !parsed ||
          typeof parsed !== "object" ||
          typeof parsed.name !== "string" ||
          typeof parsed.domain !== "string" ||
          typeof parsed.url !== "string" ||
          typeof parsed.description !== "string"
        ) {
          throw new Error("站点配置 JSON 结构不正确。");
        }

        if (
          typeof parsed.googleSiteVerification !== "undefined" &&
          typeof parsed.googleSiteVerification !== "string"
        ) {
          throw new Error("站点配置里的 Search Console 验证码必须是字符串。");
        }

        if (typeof parsed.adsensePublisherId !== "undefined" && typeof parsed.adsensePublisherId !== "string") {
          throw new Error("站点配置里的 AdSense 发布商 ID 必须是字符串。");
        }

        return parsed;
      }

      if (!Array.isArray(parsed)) {
        throw new Error("导入内容必须是数组。");
      }

      if (kind === "categories") {
        for (const item of parsed) {
          if (
            !item ||
            typeof item !== "object" ||
            typeof item.slug !== "string" ||
            typeof item.name !== "string" ||
            typeof item.description !== "string"
          ) {
            throw new Error("分类 JSON 结构不正确。");
          }
        }

        return parsed;
      }

      if (kind === "enrichments") {
        if (!parsed || typeof parsed !== "object" || Array.isArray(parsed)) {
          throw new Error("增强资料 JSON 必须是对象。");
        }

        return parsed;
      }

      for (const item of parsed) {
        if (
          !item ||
          typeof item !== "object" ||
          typeof item.slug !== "string" ||
          typeof item.name !== "string" ||
          typeof item.category !== "string" ||
          !Array.isArray(item.subcategories) ||
          typeof item.officialUrl !== "string" ||
          typeof item.pricingModel !== "string" ||
          !Array.isArray(item.coreFeatures) ||
          !Array.isArray(item.useCases) ||
          !Array.isArray(item.targetUsers)
        ) {
          throw new Error("工具 JSON 结构不正确。");
        }
      }

      return parsed;
    }

    function parseBulkRows(raw, fallbackCategory) {
      return raw
        .split("\n")
        .map((line) => line.trim())
        .filter(Boolean)
        .map((line) => {
          const columns = line.includes("|")
            ? line.split("|").map((item) => item.trim())
            : line.split("\t").map((item) => item.trim());

          const [
            name = "",
            slug = "",
            category = "",
            officialUrl = "",
            pricingModel = "",
            subcategories = "",
            coreFeatures = "",
            useCases = "",
            targetUsers = ""
          ] = columns;

          return {
            name,
            slug,
            category: category || fallbackCategory,
            officialUrl,
            pricingModel,
            subcategories: subcategories.split(",").map((item) => item.trim()).filter(Boolean),
            coreFeatures: coreFeatures.split(",").map((item) => item.trim()).filter(Boolean),
            useCases: useCases.split(",").map((item) => item.trim()).filter(Boolean),
            targetUsers: targetUsers.split(",").map((item) => item.trim()).filter(Boolean)
          };
        });
    }

    function buildReadinessChecks() {
      const siteUrl = (state.site.url || "").toLowerCase();
      const siteDomain = (state.site.domain || "").toLowerCase();
      const contactEmail = (state.site.contactEmail || "").toLowerCase();
      const adsensePublisherId = (state.site.adsensePublisherId || "").trim();
      const googleSiteVerification = (state.site.googleSiteVerification || "").trim();

      return [
        {
          key: "production-domain",
          label: "生产域名",
          ok: !siteUrl.includes("example.com") && !siteDomain.includes("example.com"),
          detail:
            !siteUrl.includes("example.com") && !siteDomain.includes("example.com")
              ? "域名看起来已经替换成正式值。"
              : "还在使用 example.com，正式部署前需要替换。"
        },
        {
          key: "contact-email",
          label: "联系邮箱",
          ok: Boolean(contactEmail) && !contactEmail.includes("example.com"),
          detail:
            Boolean(contactEmail) && !contactEmail.includes("example.com")
              ? "联系邮箱看起来可用于真实对外联系。"
              : "联系邮箱仍是示例值，送审前需要替换。"
        },
        {
          key: "adsense-publisher",
          label: "AdSense 发布商 ID",
          ok: Boolean(adsensePublisherId),
          detail: adsensePublisherId ? "已填写 AdSense 发布商 ID。" : "还没有填写 AdSense 发布商 ID。"
        },
        {
          key: "gsc-verification",
          label: "GSC 验证码",
          ok: Boolean(googleSiteVerification),
          detail: googleSiteVerification ? "已填写 Search Console 验证码。" : "还没有填写 Search Console 验证码。"
        },
        {
          key: "categories-present",
          label: "分类数量",
          ok: state.categories.length > 0,
          detail: state.categories.length > 0 ? `当前共有 ${state.categories.length} 个分类。` : "还没有分类。"
        },
        {
          key: "tools-present",
          label: "工具数量",
          ok: state.tools.length > 0,
          detail: state.tools.length > 0 ? `当前共有 ${state.tools.length} 个工具。` : "还没有工具。"
        }
      ];
    }

    async function ensureFilePermission(handle) {
      if (!handle) return false;
      const current = await handle.queryPermission({ mode: "readwrite" });
      if (current === "granted") return true;
      const requested = await handle.requestPermission({ mode: "readwrite" });
      return requested === "granted";
    }

    function serializeExport() {
      return {
        site: JSON.stringify(state.site, null, 2),
        categories: JSON.stringify(state.categories, null, 2),
        tools: JSON.stringify(state.tools, null, 2),
        enrichments: JSON.stringify(state.enrichments || {}, null, 2)
      };
    }

    function getIssues() {
      const issues = [];
      const categorySlugs = new Set();
      const toolSlugs = new Set();

      if (!state.site.name.trim()) issues.push("站点名称不能为空");
      if (!state.site.url.trim()) issues.push("站点完整 URL 不能为空");

      for (const category of state.categories) {
        if (!category.slug.trim()) issues.push("存在 slug 为空的分类");
        if (categorySlugs.has(category.slug)) issues.push(`分类 slug 重复：${category.slug}`);
        categorySlugs.add(category.slug);
      }

      for (const tool of state.tools) {
        if (!tool.slug.trim()) issues.push("存在 slug 为空的工具");
        if (toolSlugs.has(tool.slug)) issues.push(`工具 slug 重复：${tool.slug}`);
        if (!categorySlugs.has(tool.category)) issues.push(`工具 ${tool.name || tool.slug || "未命名工具"} 关联了不存在的分类：${tool.category}`);
        toolSlugs.add(tool.slug);
      }

      return issues;
    }

    function setCategoryIndex(index) {
      selectedCategoryIndex = index;
      render();
    }

    function setToolIndex(index) {
      selectedToolIndex = index;
      render();
    }

    function scrollToPanel(panelId) {
      const target = document.getElementById(panelId);
      if (target) {
        const top = window.scrollY + target.getBoundingClientRect().top - 104;
        window.scrollTo({ top, behavior: "smooth" });
      }
    }

    function findToolIndexByQuery(query) {
      const q = query.trim().toLowerCase();
      if (!q) return -1;

      const exactIndex = state.tools.findIndex(
        (tool) => tool.name.toLowerCase() === q || tool.slug.toLowerCase() === q
      );
      if (exactIndex >= 0) return exactIndex;

      return state.tools.findIndex(
        (tool) => tool.name.toLowerCase().includes(q) || tool.slug.toLowerCase().includes(q)
      );
    }

    function downloadFile(filename, content) {
      const blob = new Blob([content], { type: "application/json;charset=utf-8" });
      const url = URL.createObjectURL(blob);
      const anchor = document.createElement("a");
      anchor.href = url;
      anchor.download = filename;
      anchor.click();
      URL.revokeObjectURL(url);
    }

    async function copyCurrentExport() {
      const payload = serializeExport();
      await navigator.clipboard.writeText(payload[exportKey]);
    }

    function renderStatus() {
      const issues = getIssues();
      statusNode.innerHTML = `
        <span class="studio-chip">分类 ${state.categories.length}</span>
        <span class="studio-chip">工具 ${state.tools.length}</span>
        <span class="studio-chip">导出模式：${exportKey}</span>
        <span class="studio-chip ${issues.length ? "studio-chip-danger" : ""}">
          ${issues.length ? `存在 ${issues.length} 个待修问题` : "当前数据结构通过基础检查"}
        </span>
      `;
    }

    function renderCategoryList() {
      if (!state.categories.length) {
        categoryListNode.innerHTML = '<p class="section-lead">还没有分类，先新增一个。</p>';
        return;
      }

      categoryListNode.innerHTML = state.categories
        .map((category, index) => {
          const toolCount = state.tools.filter((tool) => tool.category === category.slug).length;
          return `
          <button type="button" class="studio-list-item ${index === selectedCategoryIndex ? "studio-list-item-active" : ""}" data-category-index="${index}">
            <strong>${category.name || "未命名分类"}</strong>
            <div class="studio-list-item-meta">
              <span class="studio-pill">${category.slug || "slug 待填"}</span>
              <span class="studio-pill">${toolCount} tools</span>
            </div>
            <small>${category.description || "暂无描述"}</small>
          </button>
        `;
        })
        .join("");
    }

    function renderToolList() {
      const filtered = state.tools
        .map((tool, index) => ({ tool, index }))
        .filter(({ tool }) => {
          if (!toolSearch.trim()) return true;
          const q = toolSearch.trim().toLowerCase();
          return tool.name.toLowerCase().includes(q) || tool.slug.toLowerCase().includes(q);
        });

      if (!filtered.length) {
        toolListNode.innerHTML = '<p class="section-lead">没有匹配的工具。</p>';
        return;
      }

      toolListNode.innerHTML = filtered
        .map(({ tool, index }) => `
          <button type="button" class="studio-list-item ${index === selectedToolIndex ? "studio-list-item-active" : ""}" data-tool-index="${index}">
            <strong>${tool.name || "未命名工具"}</strong>
            <div class="studio-list-item-meta">
              <span class="studio-pill">${tool.slug || "slug 待填"}</span>
              <span class="studio-pill">${tool.category || "未关联分类"}</span>
              <span class="studio-pill">${tool.pricingModel || "pricing n/a"}</span>
            </div>
            <small>${tool.useCases?.slice(0, 2).join(" · ") || "定价模型待填"}</small>
          </button>
        `)
        .join("");
    }

    function renderCategoryEditor() {
