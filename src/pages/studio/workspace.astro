    fileHandleListNode.addEventListener("click", async (event) => {
      const button = event.target.closest("[data-file-action]");
      if (!button) return;

      const action = button.dataset.fileAction;
      const key = button.dataset.fileKey;

      if (!fileAccessSupported) {
        alert("当前浏览器不支持直接回写本地文件，请继续使用导出下载。");
        return;
      }

      if (action === "bind") {
        try {
          const handle = await window.showSaveFilePicker({
            suggestedName: `${key}.json`,
            types: [
              {
                description: "JSON 文件",
                accept: {
                  "application/json": [".json"]
                }
              }
            ]
          });

          fileHandles[key] = handle;
          fileHandleStatus[key] = `已绑定：${handle.name}`;
          await setStoredHandle(key, handle);
          renderFileHandlePanel();
        } catch (error) {
          if (error?.name !== "AbortError") {
            alert(error instanceof Error ? error.message : String(error));
          }
        }
        return;
      }

      if (action === "save") {
        const handle = fileHandles[key];
        if (!handle) {
          alert("这个文件还没有绑定。");
          return;
        }

        try {
          const allowed = await ensureFilePermission(handle);
          if (!allowed) {
            alert("没有获得该文件的写入权限。");
            return;
          }

          const writable = await handle.createWritable();
          await writable.write(serializeExport()[key]);
          await writable.close();
          fileHandleStatus[key] = `已写入：${handle.name}`;
          renderFileHandlePanel();
        } catch (error) {
          alert(error instanceof Error ? error.message : String(error));
        }
        return;
      }

      if (action === "clear") {
        fileHandles[key] = null;
        fileHandleStatus[key] = "未绑定文件";
        await clearStoredHandle(key);
        renderFileHandlePanel();
      }
    });

    document.getElementById("save-bound-files").addEventListener("click", async () => {
      if (!fileAccessSupported) {
        alert("当前浏览器不支持直接回写本地文件。");
        return;
      }

      const boundKeys = exportKeys.filter((key) => fileHandles[key]);
      if (!boundKeys.length) {
        alert("先至少绑定一个 JSON 文件。");
        return;
      }

      for (const key of boundKeys) {
        const handle = fileHandles[key];
        const allowed = await ensureFilePermission(handle);
        if (!allowed) {
          fileHandleStatus[key] = `未获权限：${handle.name}`;
          continue;
        }

        const writable = await handle.createWritable();
        await writable.write(serializeExport()[key]);
        await writable.close();
        fileHandleStatus[key] = `已写入：${handle.name}`;
      }

      renderFileHandlePanel();
    });

