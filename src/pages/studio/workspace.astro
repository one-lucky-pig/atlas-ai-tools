      event.preventDefault();
      document.getElementById("studio-quick-create-tool").click();
    });

    document.querySelectorAll("[data-scroll-target]").forEach((button) => {
      button.addEventListener("click", () => {
        scrollToPanel(button.dataset.scrollTarget);
      });
    });

    Object.entries(siteFields).forEach(([key, input]) => {
      input.addEventListener("input", (event) => {
        state.site[key] = event.currentTarget.value;
        saveState();
        renderStatus();
        renderExport();
      });
    });

    Object.entries({
      slug: categoryFields.slug,
      name: categoryFields.name,
      description: categoryFields.description
    }).forEach(([key, input]) => {
      input.addEventListener("input", (event) => {
        const category = state.categories[selectedCategoryIndex];
        if (!category) return;
        const nextValue = event.currentTarget.value;

        if (key === "slug") {
          const previousSlug = category.slug;
          category.slug = nextValue;
          state.tools.forEach((tool) => {
            if (tool.category === previousSlug) {
              tool.category = nextValue;
            }
          });
        } else {
          category[key] = nextValue;
        }

        saveState();
        render();
      });
    });

    const toolFieldMap = {
      slug: { node: toolFields.slug, parse: (value) => value },
      name: { node: toolFields.name, parse: (value) => value },
      category: { node: toolFields.category, parse: (value) => value },
      officialUrl: { node: toolFields.officialUrl, parse: (value) => value },
      pricingModel: { node: toolFields.pricingModel, parse: (value) => value },
      subcategories: { node: toolFields.subcategories, parse: linesToList },
      coreFeatures: { node: toolFields.coreFeatures, parse: linesToList },
      useCases: { node: toolFields.useCases, parse: linesToList },
      targetUsers: { node: toolFields.targetUsers, parse: linesToList }
    };

    Object.entries(toolFieldMap).forEach(([key, config]) => {
      config.node.addEventListener("input", (event) => {
        const tool = state.tools[selectedToolIndex];
        if (!tool) return;
        const nextValue = config.parse(event.currentTarget.value);

        if (key === "slug") {
          const previousSlug = tool.slug;
          tool.slug = nextValue;

          if (previousSlug && previousSlug !== nextValue && state.enrichments?.[previousSlug]) {
            state.enrichments[nextValue] = state.enrichments[previousSlug];
            delete state.enrichments[previousSlug];
          }
        } else {
          tool[key] = nextValue;
        }

        saveState();
        render();
      });
    });

    async function hydrateStoredHandles() {
      if (!fileAccessSupported) {
        render();
        return;
      }

      for (const key of exportKeys) {
        try {
          const handle = await getStoredHandle(key);
          if (handle) {
            fileHandles[key] = handle;
            fileHandleStatus[key] = `已绑定：${handle.name}`;
          }
        } catch {
          fileHandleStatus[key] = "读取绑定失败，可重新绑定。";
        }
      }

      render();
    }

    void hydrateStoredHandles();
  </script>
</BaseLayout>
