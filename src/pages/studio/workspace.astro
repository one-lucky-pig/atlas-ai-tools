    async function refreshBridgeStatus() {
      try {
        const response = await fetch(`${studioBridgeUrl}/health`);
        if (!response.ok) {
          throw new Error(`Bridge responded with ${response.status}`);
        }

        const payload = await response.json();
        bridgeState = {
          ...bridgeState,
          ok: true,
          busy: Boolean(payload.busy),
          jobs: payload.jobs || [],
          message: payload.busy ? "桥接服务在线，任务执行中。" : "桥接服务在线，可触发本地任务。"
        };
      } catch {
        bridgeState = {
          ...bridgeState,
          ok: false,
          busy: false,
          jobs: [],
          message: "未检测到桥接服务，请先运行 npm run studio:bridge。"
        };
      }

      renderBridgePanel();
    }

    async function runBridgeJob(jobId) {
      bridgeState = {
        ...bridgeState,
        busy: true,
        message: `正在执行任务：${jobId}`,
        log: ""
      };
      renderBridgePanel();

      try {
        const response = await fetch(`${studioBridgeUrl}/run`, {
          method: "POST",
          headers: {
            "content-type": "application/json"
          },
          body: JSON.stringify({ job: jobId })
        });

        const payload = await response.json();
        if (!response.ok) {
          throw new Error(payload.error || `Bridge responded with ${response.status}`);
        }

        bridgeState = {
          ...bridgeState,
          ok: true,
          busy: false,
          message: payload.success ? `${payload.label} 已完成。` : `${payload.label} 执行失败。`,
          log: [payload.stdout, payload.stderr].filter(Boolean).join("\n\n")
        };
      } catch (error) {
        bridgeState = {
          ...bridgeState,
          ok: false,
          busy: false,
          message: "任务执行失败或桥接服务不可用。",
          log: error instanceof Error ? error.message : String(error)
        };
      }

      await refreshBridgeStatus();
      bridgeLogNode.value = bridgeState.log;
    }

    async function runStudioEnrichment(force = false) {
      const tool = state.tools[selectedToolIndex];
      if (!tool) {
        alert("先选择一个工具。");
        return;
      }

      enrichmentState = {
        provider: "",
        cached: false,
        message: "正在请求 AI 补全..."
      };
      renderEnrichmentPanel();

      try {
        const response = await fetch(`${studioBridgeUrl}/enrich-tool`, {
          method: "POST",
          headers: {
            "content-type": "application/json"
          },
          body: JSON.stringify({
            tool,
            categories: state.categories,
            force
          })
        });

        const payload = await response.json();
        if (!response.ok) {
          throw new Error(payload.error || `Bridge responded with ${response.status}`);
        }

        state.enrichments = state.enrichments || {};
        state.enrichments[tool.slug] = payload.enrichment;
        enrichmentState = {
          provider: payload.provider,
          cached: Boolean(payload.cached),
          message: payload.cached ? "命中本地缓存并已载入。" : "已生成新的增强资料。"
        };
        saveState();
        render();
      } catch (error) {
        enrichmentState = {
          provider: "",
          cached: false,
          message: error instanceof Error ? error.message : String(error)
        };
        renderEnrichmentPanel();
      }
    }

